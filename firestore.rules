
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function staffPath() {
      return /databases/$(database)/documents/staff/$(request.auth.uid);
    }

    function staffExists() {
      return isSignedIn() && exists(staffPath());
    }

    function staffData() {
      return get(staffPath()).data;
    }

    function isActiveStaff() {
      return staffExists() && staffData().status == 'active';
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.platformAdmin == true ||
        (staffExists() && staffData().role == 'admin')
      );
    }

    function hasStoreAccess(storeId) {
      return isAdmin() || (
        isActiveStaff()
        && (staffData().assignedStoreIds is list)
        && staffData().assignedStoreIds.hasAny([storeId])
      );
    }

    // ✅ Collection Group Rules (works for collectionGroup queries anywhere)
    match /{path=**}/kitchentickets/{ticketId} {
      allow read: if isActiveStaff();
    }

    match /{path=**}/activityLogs/{logId} {
    allow read: if isActiveStaff();
    }


    // ✅ Staff Profile (Admins can manage, users can get their own)
    match /staff/{uid} {
      // Admins can read/write any staff profile.
      allow read, write: if isAdmin();
      
      // A non-admin user can read their own profile.
      allow get: if isSignedIn() && request.auth.uid == uid;
      
      // A user can create their own profile during signup.
      allow create: if isSignedIn() && request.auth.uid == uid;
    }

    // ✅ Real-time KDS Projections
    match /stores/{storeId}/rtKdsTickets/{docPath=**} {
      allow read, write: if hasStoreAccess(storeId);
    }

    // Store scoped (everything else): no deletes except admin
    match /stores/{storeId}/{docPath=**} {
      allow read, create, update: if hasStoreAccess(storeId);
      allow delete: if isAdmin();
    }

    // Root (non-store)
    match /{collection}/{docId} {
      allow read, create, update: if isActiveStaff();
      allow delete: if isAdmin();
    }

    match /{collection}/{docId}/{docPath=**} {
      allow read, create, update: if isActiveStaff();
      allow delete: if isAdmin();
    }
  }
}

