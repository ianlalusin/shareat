rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function staffPath() {
      return /databases/$(database)/documents/staff/$(request.auth.uid);
    }

    function staffExists() {
      return isSignedIn() && exists(staffPath());
    }

    function staffData() {
      return get(staffPath()).data;
    }

    function isActiveStaff() {
      return staffExists() && staffData().status == 'active';
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.platformAdmin == true ||
        (staffExists() && staffData().role == 'admin')
      );
    }

    function hasStoreAccess(storeId) {
      // Admin sees all stores
      if (isAdmin()) return true;

      // Active staff must have storeId in assignedStoreIds
      return isActiveStaff()
        && (staffData().assignedStoreIds is list)
        && (storeId in staffData().assignedStoreIds);
    }

    // STORE-SCOPED
    match /stores/{storeId}/{documents=**} {
      allow read, create, update: if hasStoreAccess(storeId);
      allow delete: if isAdmin();
    }

    // ROOT (non-store) + all its subcollections
    match /{collection}/{docId} {
      allow read, create, update: if isActiveStaff();
      allow delete: if isAdmin();

      match /{subcollection}/{subdoc=**} {
        allow read, create, update: if isActiveStaff();
        allow delete: if isAdmin();
      }
    }
  }
}
