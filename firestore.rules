rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isPlatformAdmin() {
      return request.auth.token.platformAdmin == true;
    }
    
    function staffDocPath(uid) {
      return /databases/$(database)/documents/staff/$(uid);
    }
    
    function staffData(uid) {
      return get(staffDocPath(uid)).data;
    }

    function isUserActive(uid) {
      return exists(staffDocPath(uid)) && staffData(uid).status == 'active';
    }

    function isRole(uid, role) {
      return isUserActive(uid) && staffData(uid).role == role;
    }
    
    function isManager(uid) {
      let role = staffData(uid).role;
      return role == 'admin' || role == 'manager';
    }
    
    function isCashier(uid) {
      return isManager(uid) || isRole(uid, 'cashier');
    }

    function isServer(uid) {
        return isCashier(uid) || isRole(uid, 'server');
    }

    function isKitchen(uid) {
        return isManager(uid) || isRole(uid, 'kitchen');
    }

    function hasStoreAccess(uid, storeId) {
      let data = staffData(uid);
      return isUserActive(uid) && 
             (data.assignedStoreIds is list) && 
             (storeId in data.assignedStoreIds);
    }

    function isStoreManager(uid, storeId) {
      return hasStoreAccess(uid, storeId) && isManager(uid);
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // =====================================================================
    // Collection Rules
    // =====================================================================

    match /staff/{staffId} {
      allow get: if isPlatformAdmin() || isOwner(staffId);
      allow list: if isPlatformAdmin();
      allow create: if isOwner(staffId); // New user creating their own doc
      allow update: if isPlatformAdmin() || 
                      (isOwner(staffId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'address', 'contactNumber', 'photoURL', 'updatedAt']));
      allow delete: if isPlatformAdmin();
    }

    // Global Data (Products, Flavors, etc.)
    match /{collection}/{docId} 
        where collection in ['products', 'flavors', 'refills', 'packages', 'addonCategories'] {
      allow read: if isSignedIn();
      allow write: if isPlatformAdmin();
    }
    
    match /stores/{storeId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isPlatformAdmin();

        // Store-level Configuration
        match /{collection}/{docId} 
            where collection in [
                'inventory', 'storePackages', 'storeRefills', 'storeFlavors',
                'menuSchedules', 'kitchenLocations', 'tables',
                'storeCharges', 'storeDiscounts', 'storeModesOfPayment', 'receiptSettings'
            ] {
            allow read: if isPlatformAdmin() || hasStoreAccess(request.auth.uid, storeId);
            allow write: if isPlatformAdmin() || isStoreManager(request.auth.uid, storeId);
        }
        
        // --- Store Operational Data ---

        // Counters for receipt numbers, etc.
        match /counters/{counterId} {
            allow read: if isPlatformAdmin() || hasStoreAccess(request.auth.uid, storeId);
            allow write: if isPlatformAdmin() || (hasStoreAccess(request.auth.uid, storeId) && isCashier(request.auth.uid));
        }

        // Sessions and their subcollections
        match /sessions/{sessionId} {
            allow read: if isPlatformAdmin() || hasStoreAccess(request.auth.uid, storeId);
            allow create: if isPlatformAdmin() || (hasStoreAccess(request.auth.uid, storeId) && isCashier(request.auth.uid));
            allow update: if isPlatformAdmin() || (hasStoreAccess(request.auth.uid, storeId) && (isServer(request.auth.uid) || isKitchen(request.auth.uid)));
            allow delete: if isPlatformAdmin();

            match /{subcollection}/{docId} 
                where subcollection in ['kitchentickets', 'sessionBillLines', 'payments'] {
                allow read, write: if isPlatformAdmin() || hasStoreAccess(request.auth.uid, storeId);
            }
        }
        
        // Receipts and Revisions
        match /receipts/{receiptId} {
            allow read, create: if isPlatformAdmin() || (hasStoreAccess(request.auth.uid, storeId) && isCashier(request.auth.uid));
            allow update: if isPlatformAdmin() || isStoreManager(request.auth.uid, storeId);
            allow delete: if isPlatformAdmin();

            match /revisions/{revisionId} {
                allow read, write: if isPlatformAdmin() || isStoreManager(request.auth.uid, storeId);
            }
        }

        // --- Analytics & Projections ---
        
        // Analytics Rollups
        match /{collection}/{docId}
            where collection in ['analytics', 'analyticsMonths', 'analyticsYears', 'dashPresets'] {
            allow read: if isPlatformAdmin() || isStoreManager(request.auth.uid, storeId);
            allow write: if isPlatformAdmin() || (hasStoreAccess(request.auth.uid, storeId) && isCashier(request.auth.uid));
        }
        
        // Store Config Cache (read by all, written by managers)
        match /storeConfig/{wildcard=**} {
            allow read: if isPlatformAdmin() || hasStoreAccess(request.auth.uid, storeId);
            allow write: if isPlatformAdmin() || isStoreManager(request.auth.uid, storeId);
        }

        // Operational Projections (opPages)
        match /opPages/{wildcard=**} {
            // Broad access for projections. UI logic controls specific actions.
            // These are intermediate, non-critical data structures.
            allow read, write: if isPlatformAdmin() || hasStoreAccess(request.auth.uid, storeId);
        }

        // Legacy Activity Logs
        match /activityLogs/{logId} {
            allow read, create: if isPlatformAdmin() || hasStoreAccess(request.auth.uid, storeId);
            allow update, delete: if isPlatformAdmin();
        }

        // New Partitioned Activity Logs
        match /activityLogsByDay/{dayId}/logs/{logId} {
            allow read, create: if isPlatformAdmin() || hasStoreAccess(request.auth.uid, storeId);
            allow update, delete: if isPlatformAdmin();
        }
    }
  }
}
