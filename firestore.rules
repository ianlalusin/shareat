rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isPlatformAdmin() {
      return isSignedIn() && request.auth.token.platformAdmin == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function staffDocPath() {
      return /databases/$(database)/documents/staff/$(request.auth.uid);
    }

    function isActiveStaff() {
      return exists(staffDocPath()) && get(staffDocPath()).data.status == 'active';
    }

    function staffDoc() {
      return get(staffDocPath()).data;
    }

    function hasStoreAccess(storeId) {
      return isPlatformAdmin() || (isActiveStaff() && storeId in staffDoc().assignedStoreIds);
    }

    function isStoreManager(storeId) {
      return isPlatformAdmin() || (isActiveStaff() && storeId in staffDoc().assignedStoreIds && staffDoc().role == 'manager');
    }

    function canManageStoreStaff(storeId) {
      return isPlatformAdmin() || isStoreManager(storeId);
    }

    function isCreatingOwnValidStaffDoc(staffId) {
      return isOwner(staffId) && request.resource.data.staffId == staffId;
    }

    // --------------------------------
    // Collection Rules
    // --------------------------------

    // Global collections - readable by any signed-in user, writable only by platform admins
    match /products/{productId} { allow read: if isSignedIn(); allow write: if isPlatformAdmin(); }
    match /flavors/{flavorId} { allow read: if isSignedIn(); allow write: if isPlatformAdmin(); }
    match /refills/{refillId} { allow read: if isSignedIn(); allow write: if isPlatformAdmin(); }
    match /packages/{packageId} { allow read: if isSignedIn(); allow write: if isPlatformAdmin(); }
    match /addonCategories/{categoryId} { allow read: if isSignedIn(); allow write: if isPlatformAdmin(); }
    match /expenseEntries/{expenseEntryId} { allow read: if isSignedIn(); allow create, update, delete: if isPlatformAdmin(); }

    // Store management (only platform admins can create/edit stores)
    match /stores/{storeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isPlatformAdmin();
    }
    
    // Global staff profiles
    match /staff/{staffId} {
      allow get: if isOwner(staffId) || isPlatformAdmin();
      allow list: if isPlatformAdmin();
      allow create: if isCreatingOwnValidStaffDoc(staffId);
      allow update: if (isOwner(staffId) &&
                        !('role' in request.resource.data) &&
                        !('status' in request.resource.data) &&
                        !('assignedStoreIds' in request.resource.data) &&
                        !('staffId' in request.resource.data) &&
                        !('id' in request.resource.data))
                     || isPlatformAdmin();
      allow delete: if isPlatformAdmin();
    }
    
    // Manager-only settings pages
    match /stores/{storeId}/storePackages/{packageId} { allow read: if hasStoreAccess(storeId); allow write: if isStoreManager(storeId); }
    match /stores/{storeId}/storeRefills/{refillId} { allow read: if hasStoreAccess(storeId); allow write: if isStoreManager(storeId); }
    match /stores/{storeId}/storeFlavors/{flavorId} { allow read: if hasStoreAccess(storeId); allow write: if isStoreManager(storeId); }
    match /stores/{storeId}/menuSchedules/{scheduleId} { allow read: if hasStoreAccess(storeId); allow write: if isStoreManager(storeId); }
    match /stores/{storeId}/kitchenLocations/{locationId} { allow read: if hasStoreAccess(storeId); allow write: if isStoreManager(storeId); }
    match /stores/{storeId}/tables/{tableId} { allow read: if hasStoreAccess(storeId); allow write: if isStoreManager(storeId); }
    match /stores/{storeId}/storeCharges/{chargeId} { allow read: if hasStoreAccess(storeId); allow write: if isStoreManager(storeId); }
    match /stores/{storeId}/storeDiscounts/{discountId} { allow read: if hasStoreAccess(storeId); allow write: if isStoreManager(storeId); }
    match /stores/{storeId}/storeModesOfPayment/{mopId} { allow read: if hasStoreAccess(storeId); allow write: if isStoreManager(storeId); }
    match /stores/{storeId}/receiptSettings/{settingsId} { allow read: if hasStoreAccess(storeId); allow write: if isStoreManager(storeId); }
    
    // General store subcollections (sessions, tickets, etc.)
    match /stores/{storeId}/{allChildren=**} {
      allow read, write: if hasStoreAccess(storeId);
    }
  }
}
