
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions (NEW MODEL)
    // =====================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    // Global super-admin (ONLY via custom claim)
    function isPlatformAdmin() {
      return isSignedIn() && request.auth.token.platformAdmin == true;
    }

    // Path to the user's single source of truth document.
    function staffDocPath() {
      return /databases/$(database)/documents/staff/$(request.auth.uid);
    }
    
    function staffData() {
      // Note: Always check exists() before calling get().
      return get(staffDocPath()).data;
    }

    // Checks if the user has a staff document and its status is "active".
    function isActiveStaff() {
      return exists(staffDocPath()) && staffData().status == 'active';
    }

    // Checks if the user is assigned to a specific store.
    function isAssignedToStore(storeId) {
       return (staffData().assignedStoreIds is list) && (storeId in staffData().assignedStoreIds);
    }

    // Gatekeeper function for all store-level data access.
    function hasStoreAccess(storeId) {
      return isPlatformAdmin() || (isActiveStaff() && isAssignedToStore(storeId));
    }

    // --- Role-Based Helpers ---
    // These check the user's role from their /staff document.
    
    function isRole(role) {
      // Must be an active staff member to have any role.
      return isActiveStaff() && staffData().role == role;
    }
    
    // Hierarchical roles: Manager can do everything a Cashier can, etc.
    function isManager() {
      return isPlatformAdmin() || isRole('admin') || isRole('manager');
    }
    
    function isCashier() {
        return isManager() || isRole('cashier');
    }

    function isServer() {
      return isManager() || isRole('cashier') || isRole('server');
    }
    
    function isKitchen() {
      return isManager() || isRole('kitchen');
    }
    
    function isStoreManager(storeId) {
      // Checks if the user has access to the store AND has the manager role.
      return hasStoreAccess(storeId) && isManager();
    }

    // --- Data Validation Helpers ---

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Enforces immutability for specific fields during an update.
    function isUpdatingOwnProfile(staffId) {
      // List of fields a user CANNOT change for themselves.
      let protectedFields = ['role', 'status', 'assignedStoreIds', 'staffId', 'isPlatformAdmin'];
      
      return isOwner(staffId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(protectedFields) == false
        && request.resource.data.staffId == resource.data.staffId; // staffId is immutable
    }
    
    function isCreatingOwnValidStaffDoc(staffId) {
        return isOwner(staffId)
            && request.resource.data.staffId == staffId;
    }

    // =====================================================================
    // Collection Rules
    // =====================================================================

    // -------------------------------------------------
    // Root-level Collections
    // -------------------------------------------------

    match /staff/{staffId} {
      allow get: if isOwner(staffId) || isPlatformAdmin();
      allow list: if isPlatformAdmin(); // Only platform admins can list all staff.
      allow create: if isCreatingOwnValidStaffDoc(staffId);
      allow update: if isPlatformAdmin() || isUpdatingOwnProfile(staffId);
      allow delete: if isPlatformAdmin();
    }

    // Global data, readable by any active staff, writable only by platform admins.
    match /products/{productId} { allow read: if isActiveStaff(); allow write: if isPlatformAdmin(); }
    match /flavors/{flavorId} { allow read: if isActiveStaff(); allow write: if isPlatformAdmin(); }
    match /refills/{refillId} { allow read: if isActiveStaff(); allow write: if isPlatformAdmin(); }
    match /packages/{packageId} { allow read: if isActiveStaff(); allow write: if isPlatformAdmin(); }
    match /addonCategories/{categoryId} { allow read: if isActiveStaff(); allow write: if isPlatformAdmin(); }
    match /expenseEntries/{expenseEntryId} { allow read: if isActiveStaff(); allow write: if isPlatformAdmin(); }

    // -------------------------------------------------
    // Store & Subcollection Rules
    // -------------------------------------------------

    match /stores/{storeId} {
      // Any signed-in user can get/list store details.
      allow get, list: if isSignedIn();
      // Only platform admins can create, modify, or delete store documents.
      allow create, update, delete: if isPlatformAdmin();

      // --- Store Management (Manager-only) ---
      // These collections define the settings FOR a store.
      match /storePackages/{docId} { allow read: if hasStoreAccess(storeId); allow write: if isStoreManager(storeId); }
      match /storeRefills/{docId} { allow read: if hasStoreAccess(storeId); allow write: if isStoreManager(storeId); }
      match /storeFlavors/{docId} { allow read: if hasStoreAccess(storeId); allow write: if isStoreManager(storeId); }
      match /menuSchedules/{docId} { allow read: if hasStoreAccess(storeId); allow write: if isStoreManager(storeId); }
      match /kitchenLocations/{docId} { allow read: if hasStoreAccess(storeId); allow write: if isStoreManager(storeId); }
      match /tables/{docId} { allow read: if hasStoreAccess(storeId); allow write: if isStoreManager(storeId); }
      match /inventory/{docId} { allow read: if hasStoreAccess(storeId); allow write: if isStoreManager(storeId); }
      match /storeCharges/{docId} { allow read: if hasStoreAccess(storeId); allow write: if isStoreManager(storeId); }
      match /storeDiscounts/{docId} { allow read: if hasStoreAccess(storeId); allow write: if isStoreManager(storeId); }
      match /storeModesOfPayment/{docId} { allow read: if hasStoreAccess(storeId); allow write: if isStoreManager(storeId); }
      match /receiptSettings/{docId} { allow read: if hasStoreAccess(storeId); allow write: if isStoreManager(storeId); }
      
       // Allow staff management within a store by managers or platform admins.
      match /staff/{staffId} {
        allow get, list: if hasStoreAccess(storeId);
        allow create, update: if isStoreManager(storeId);
        allow delete: if isStoreManager(storeId);
      }

      // --- Operational Data (Broader Access) ---
      // These collections are for daily operations.
      
      // Counters for receipt numbers, etc.
      match /counters/{docId} {
        allow read: if hasStoreAccess(storeId);
        allow write: if hasStoreAccess(storeId) && isCashier();
      }

      // Finalized receipts
      match /receipts/{receiptId} {
        allow read: if hasStoreAccess(storeId);
        // Created by cashier during payment.
        allow create: if hasStoreAccess(storeId) && isCashier();
        // Updatable by managers/admins for corrections.
        allow update: if hasStoreAccess(storeId) && isManager();
        allow delete: if isPlatformAdmin(); // Deletions are admin-only
      }

      // Analytics data (written to by server functions or client-side on payment)
      match /analytics/{dayId} {
        allow read: if hasStoreAccess(storeId) && isManager();
        allow write: if hasStoreAccess(storeId) && isCashier();
        match /{subcol}/{docId} {
            allow read: if hasStoreAccess(storeId) && isManager();
            allow write: if hasStoreAccess(storeId) && isCashier();
        }
      }
       match /analyticsMonths/{monthId} {
        allow read: if hasStoreAccess(storeId) && isManager();
        allow write: if hasStoreAccess(storeId) && isCashier();
         match /{subcol}/{docId} {
            allow read: if hasStoreAccess(storeId) && isManager();
            allow write: if hasStoreAccess(storeId) && isCashier();
        }
      }
       match /analyticsYears/{yearId} {
        allow read: if hasStoreAccess(storeId) && isManager();
        allow write: if hasStoreAccess(storeId) && isCashier();
         match /{subcol}/{docId} {
            allow read: if hasStoreAccess(storeId) && isManager();
            allow write: if hasStoreAccess(storeId) && isCashier();
        }
      }

      // Live dining sessions and their subcollections
      match /sessions/{sessionId} {
        allow read: if hasStoreAccess(storeId);
        allow create: if hasStoreAccess(storeId) && isCashier();
        allow update: if hasStoreAccess(storeId) && isServer(); // Broad update for servers, cashiers, managers.
        allow delete: if isPlatformAdmin(); // Deletions are admin-only

        // All users with store access can see tickets and logs.
        match /kitchentickets/{ticketId} {
          allow read: if hasStoreAccess(storeId);
          allow create: if hasStoreAccess(storeId) && isServer();
          allow update: if hasStoreAccess(storeId) && (isKitchen() || isServer());
          allow delete: if isPlatformAdmin();
        }

        match /sessionBillLines/{lineId} {
            allow read: if hasStoreAccess(storeId);
            allow create, update: if hasStoreAccess(storeId) && (isCashier() || isServer());
            allow delete: if isPlatformAdmin();
        }
        
        match /payments/{paymentId} {
            allow read, create: if hasStoreAccess(storeId) && isCashier();
            allow update, delete: if isPlatformAdmin();
        }

        match /activityLogs/{logId} {
          allow read: if hasStoreAccess(storeId) && isManager();
          allow create: if hasStoreAccess(storeId) && isServer();
          allow update, delete: if false; // Logs are immutable
        }
      }
      
      // Generic ERP bucket for future use, restricted by store access.
      match /ERP/{wildcard=**} {
        allow read, write: if hasStoreAccess(storeId);
      }
    }
  }
}
