rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }

    function staffPath() {
      return /databases/$(database)/documents/staff/$(request.auth.uid);
    }
    function staffExists() { return isSignedIn() && exists(staffPath()); }
    function staffData() { return get(staffPath()).data; }
    function isActiveStaff() { return staffExists() && staffData().status == 'active'; }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.platformAdmin == true ||
        (staffExists() && staffData().role == 'admin')
      );
    }

    function hasStoreAccess(storeId) {
      return isAdmin() || (
        isActiveStaff()
        && (staffData().assignedStoreIds is list)
        && staffData().assignedStoreIds.hasAny([storeId])
      );
    }

    // -----------------------------
    // CUSTOMER AUTH (via custom token)
    // -----------------------------
    function isCustomer() {
      return isSignedIn() && request.auth.token.customer == true;
    }
    function customerStoreId() { return request.auth.token.storeId; }
    function customerSessionId() { return request.auth.token.sessionId; }

    function isLoyaltyCustomer() {
      return isSignedIn() && request.auth.token.loyaltyCustomer == true;
    }
    function loyaltyPhone() { return request.auth.token.phone; }

    function isCustomerForSession(storeId, sessionId) {
      return isCustomer()
        && customerStoreId() == storeId
        && customerSessionId() == sessionId;
    }

    function msNow() { return request.time.toMillis(); }
    function pinFieldsUnchanged() {
      return !resource.exists()
        || (
          request.resource.data.customerPin == resource.data.customerPin
          && request.resource.data.customerAccessEnabled == resource.data.customerAccessEnabled
          && request.resource.data.customerAccessExpiresAtMs == resource.data.customerAccessExpiresAtMs
        );
    }

    // -----------------------------
    // Collection Group Rules
    // -----------------------------
    match /{path=**}/kitchentickets/{ticketId} {
      allow read: if isActiveStaff();
    }
    match /{path=**}/activityLogs/{logId} {
      allow read: if isActiveStaff();
    }

    // -----------------------------
    // Staff Profiles
    // -----------------------------
    match /staff/{uid} {
      allow read, write: if isAdmin();
      allow get: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid;
    }

    // -----------------------------
    // PIN REGISTRY (STAFF + CUSTOMER)
    // -----------------------------
    match /pinRegistry/{pin} {
      // CUSTOMER: allow get only if active + not expired
      // (No list, no write)
      allow get: if isCustomer()
        && resource.data.status == 'active'
        && resource.data.expiresAtMs > msNow();

      // STAFF: read only. PIN writes now go through trusted server routes.
      allow get, list: if isActiveStaff() && hasStoreAccess(resource.data.storeId);

      allow create, update, delete: if false;
    }

    // -----------------------------
    // Real-time KDS Projections
    // -----------------------------
    match /stores/{storeId}/rtKdsTickets/{docPath=**} {
      allow read, write: if hasStoreAccess(storeId);
    }

    // -----------------------------
    // Active Sessions Projection
    // -----------------------------
    // Staff access (existing) + Customer read access to ONLY their session doc
    match /stores/{storeId}/activeSessions/{sessionId} {
      allow read: if hasStoreAccess(storeId);
      allow create, update: if hasStoreAccess(storeId) && pinFieldsUnchanged();
      allow delete: if hasStoreAccess(storeId);

      // CUSTOMER: read only if access enabled + not expired
      allow get: if isCustomerForSession(storeId, sessionId)
        && resource.data.customerAccessEnabled == true
        && resource.data.customerAccessExpiresAtMs > msNow();
    }

    // Keep your existing catch-all for staff subpaths under activeSessions if needed
    match /stores/{storeId}/activeSessions/{docPath=**} {
      allow read, write: if hasStoreAccess(storeId);
    }

    match /stores/{storeId}/closedSessions/{docPath=**} {
      allow read, write: if hasStoreAccess(storeId);
    }

    // Store scoped (everything else)
    match /stores/{storeId}/{docPath=**} {
      allow read, write, delete: if hasStoreAccess(storeId);
    }

    // -----------------------------
    // SHARELEBRATOR AUDIT LOG (server-only writes)
    // -----------------------------
    match /loyaltyLogs/{logId} {
      allow read, list: if isActiveStaff();
      allow create, update, delete: if false;
    }

    // -----------------------------
    // SHARELEBRATOR LOYALTY CUSTOMERS
    // Top-level (cross-branch). Server-only writes via Admin SDK.
    // -----------------------------
    match /customers/{phone} {
      allow get: if (isLoyaltyCustomer() && loyaltyPhone() == phone) || isActiveStaff();
      allow list: if isActiveStaff();
      allow create, update, delete: if false;

      match /pointsLedger/{ledgerId} {
        allow get, list: if (isLoyaltyCustomer() && loyaltyPhone() == phone) || isActiveStaff();
        allow create, update, delete: if false;
      }
    }

    // Root (non-store) - keep as-is, but note: pinRegistry is now explicitly handled above
    match /{collection}/{docId} {
      allow read, create, update: if isActiveStaff();
      allow delete: if isAdmin();
    }
    match /{collection}/{docId}/{docPath=**} {
      allow read, create, update: if isActiveStaff();
      allow delete: if isAdmin();
    }
  }
}