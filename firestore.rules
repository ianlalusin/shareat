rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // Checks for the 'admin' role in the user's /staff document.
      // Note: This involves a document read, which has cost implications
      // and cannot be used to secure collection list queries.
      return isSignedIn() && get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasActiveStoreAssignment(storeId) {
      let staffPath = /databases/$(database)/documents/staff/$(request.auth.uid);
      return exists(staffPath)
        && (get(staffPath).data.assignedStoreIds is list)
        && (storeId in get(staffPath).data.assignedStoreIds);
    }

    function hasStoreAccess(storeId) {
      return isAdmin() || hasActiveStoreAssignment(storeId);
    }

    function isStoreManager(storeId) {
      let assignmentPath = /databases/$(database)/documents/stores/$(storeId)/staff/$(request.auth.uid);
      return exists(assignmentPath)
        && get(assignmentPath).data.role == 'manager'
        && get(assignmentPath).data.isActive == true;
    }

    function canManageStoreStaff(storeId) {
      return isAdmin() || isStoreManager(storeId);
    }
    
    function isCreatingOwnValidStaffDoc(staffId) {
      return isOwner(staffId) && request.resource.data.staffId == staffId;
    }

    function isUpdatingOwnValidStaffDoc(staffId) {
      return isOwner(staffId) && request.resource.data.staffId == resource.data.staffId;
    }

    // --------------------------------
    // Collection Rules
    // --------------------------------

    match /stores/{storeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    
    // Store-Scoped Subcollections
    match /stores/{storeId}/{allChildren=**} {
      allow read, write: if hasStoreAccess(storeId);
    }

    // Global Collections
    match /products/{productId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /flavors/{flavorId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /refills/{refillId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /packages/{packageId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /addonCategories/{categoryId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    
    // Staff collection
    match /staff/{staffId} {
      allow get: if isOwner(staffId) || isAdmin();
      
      // To allow admins to view all users on the management page without custom claims,
      // this rule must be more permissive. Document contents are still protected by the 'get' rule.
      allow list: if isSignedIn();
      
      allow create: if isCreatingOwnValidStaffDoc(staffId);
      
      // Allow user to update own doc, but not assignments/role. Admins can update.
      allow update: if (isUpdatingOwnValidStaffDoc(staffId) && !("assignedStoreIds" in request.resource.data) && !("role" in request.resource.data))
        || isAdmin();
        
      allow delete: if isAdmin();
    }
    
    // Expense Entries - Admin only management
    match /expenseEntries/{expenseEntryId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
