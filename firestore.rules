rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------
    // Helpers
    // -------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function staffPath() {
      return /databases/$(database)/documents/staff/$(request.auth.uid);
    }

    function staffExists() {
      return isSignedIn() && exists(staffPath());
    }

    function staffData() {
      return get(staffPath()).data;
    }

    function isActiveStaff() {
      return staffExists() && staffData().status == 'active';
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.platformAdmin == true ||
        (staffExists() && staffData().role == 'admin')
      );
    }

    function hasStoreAccess(storeId) {
      // Admin sees all stores
      if (isAdmin()) return true;

      // Active staff must have storeId in assignedStoreIds (array/list)
      return isActiveStaff()
        && (staffData().assignedStoreIds is list)
        && staffData().assignedStoreIds.hasAny([storeId]);
    }

    // -------------------------
    // Store-scoped rules
    // -------------------------

    // ✅ Projections: allow store staff to delete opPages docs (needed by KDS serve/cancel)
    match /stores/{storeId}/opPages/{docPath=**} {
      allow read, create, update, delete: if hasStoreAccess(storeId);
    }

    // Everything else under a store: no deletes except admin
    match /stores/{storeId}/{docPath=**} {
      allow read, create, update: if hasStoreAccess(storeId);
      allow delete: if isAdmin();
    }

    // -------------------------
    // Root (non-store) rules
    // -------------------------
    match /{collection}/{docId} {
      allow read, create, update: if isActiveStaff();
      allow delete: if isAdmin();
    }

    match /{collection}/{docId}/{docPath=**} {
      allow read, create, update: if isActiveStaff();
      allow delete: if isAdmin();
    }
  }
}