/**
 * Firestore Security Rules (POSKDS + ERP shared project)
 *
 * Model
 * - Users live in /users/{uid}
 *   - status: "pending" | "active" | "blocked"
 *   - role: single role string (admin/manager/cashier/kitchen/server/...)
 *   - assignedStoreIds: array of storeIds the user is allowed to access
 *   - storeId: "active" store for UI switcher (must be inside assignedStoreIds)
 *
 * Goals
 * - Self signup allowed: user can create their own /users/{uid} doc as PENDING
 * - Admin approves/assigns: admin sets status=active, role, assignedStoreIds, storeId
 * - Users can only read/write store data for stores assigned to them
 * - Users cannot list all stores; they can only GET assigned store docs
 * - Users can switch active store by updating /users/{uid}.storeId (only within assignedStoreIds)
 *
 * Notes
 * - `platformAdmin` custom claim is a global override (optional).
 * - This ruleset is intentionally broad within a store for prototyping:
 *   any assigned active user can read/write under /stores/{storeId}/...
 *   Tighten per-collection later as needed.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------
    // Helpers
    // ----------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isPlatformAdmin() {
      return isSignedIn() && request.auth.token.platformAdmin == true;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userRef(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function userDoc(uid) {
      return get(userRef(uid)).data;
    }

    function myUser() {
      return userDoc(request.auth.uid);
    }

    function isMyUserDocExists() {
      return exists(userRef(request.auth.uid));
    }

    function isActiveUser() {
      // user doc must exist + status must be active, unless platform admin
      return isPlatformAdmin() ||
        (isSignedIn() && isMyUserDocExists() && myUser().status == "active");
    }

    function isAdmin() {
  return isPlatformAdmin() || (
    isActiveUser() && (
      // role string (case-insensitive)
      ((myUser().role is string) && (myUser().role.lower() == "admin")) ||
      // roles array (legacy/alternate)
      ((myUser().roles is list) && myUser().roles.hasAny(["admin"]))
    )
  );
}

function isManager() {
  return isAdmin() || (
    isActiveUser() && (
      ((myUser().role is string) && (myUser().role.lower() == "manager")) ||
      ((myUser().roles is list) && myUser().roles.hasAny(["manager"]))
    )
  );
}


    function hasStoreAccess(storeId) {
      // assignedStoreIds is the authorization scope
      return isPlatformAdmin() ||
        (isActiveUser() &&
          (myUser().assignedStoreIds is list) &&
          myUser().assignedStoreIds.hasAny([storeId]));
    }

    function isUpdatingOnly(keys) {
      // keys is a list of field names allowed to change
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(keys);
    }

    // ----------------------------
    // Users
    // ----------------------------
    match /users/{uid} {
      // Self-signup: user can create own doc as PENDING
      allow create: if isOwner(uid)
        && request.resource.data.id == uid
        && request.resource.data.status == "pending"
        // prevent self-assign / self-promote at signup
        && !("assignedStoreIds" in request.resource.data)
        && !("storeId" in request.resource.data)
        && !("role" in request.resource.data);

      // Read own profile; admins can read anyone
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();

      // Updates:
      // - Owner can update profile fields anytime (even pending), but cannot set role/assignments.
      // - Owner can set storeId ONLY if active and storeId is in assignedStoreIds.
      // - Admin can update anything.
      allow update: if isAdmin()
        || (
          isOwner(uid) && isMyUserDocExists() && (
            // A) profile edits (safe fields)
            isUpdatingOnly(["displayName", "photoURL", "address", "contactNumber", "updatedAt", "name"])
            ||
            // B) switch active store (only when active + within assignedStoreIds)
            (
              isUpdatingOnly(["storeId", "updatedAt"]) &&
              userDoc(uid).status == "active" &&
              (userDoc(uid).assignedStoreIds is list) &&
              userDoc(uid).assignedStoreIds.hasAny([request.resource.data.storeId])
            )
          )
        );

      allow delete: if isAdmin();
    }

    // ----------------------------
    // Stores (root doc)
    // ----------------------------
    match /stores/{storeId} {
      // Users should NOT be able to list all stores.
      allow list: if isAdmin();

      // Only allow reading a store doc if assigned (or platform admin).
      allow get: if hasStoreAccess(storeId);

      // Only admins can create/modify store master records.
      allow create, update, delete: if isAdmin();

      // ----------------------------
      // Everything under a store
      // ----------------------------
      match /{subpath=**} {
        allow read, write: if hasStoreAccess(storeId);
      }
    }

    // ----------------------------
    // Default deny everything else
    // ----------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
