rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isPlatformAdmin() {
      return isSignedIn() && request.auth.token.platformAdmin == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the user has an active assignment for a given store
     * using the global staff doc array: assignedStoreIds[].
     *
     * REQUIRED CHANGE:
     * - Uses /staff/{uid}.assignedStoreIds (array)
     * - NOT storeId string filtering
     * - NOT store assignment doc existence for gating store access
     */
    function hasActiveStoreAssignment(storeId) {
      let staffPath = /databases/$(database)/documents/staff/$(request.auth.uid);

      return exists(staffPath)
        && (get(staffPath).data.assignedStoreIds is list)
        && (storeId in get(staffPath).data.assignedStoreIds);
    }

    function hasStoreAccess(storeId) {
      return isPlatformAdmin() || hasActiveStoreAssignment(storeId);
    }

    /**
     * Checks if the user is an active manager for the specified store.
     * Roles remain store-scoped in /stores/{storeId}/staff/{uid}.
     * (No change in intent; just made safe with exists().)
     */
    function isStoreManager(storeId) {
      let assignmentPath = /databases/$(database)/documents/stores/$(storeId)/staff/$(request.auth.uid);

      return exists(assignmentPath)
        && get(assignmentPath).data.role == 'manager'
        && get(assignmentPath).data.isActive == true;
    }

    function canManageStoreStaff(storeId) {
      return isPlatformAdmin() || isStoreManager(storeId);
    }

    function isCreatingOwnValidStaffDoc(staffId) {
      return isOwner(staffId) && request.resource.data.staffId == staffId;
    }

    function isUpdatingOwnValidStaffDoc(staffId) {
      return isOwner(staffId) && request.resource.data.staffId == resource.data.staffId;
    }

    // --------------------------------
    // Collection Rules
    // --------------------------------

    match /stores/{storeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isPlatformAdmin();

        // --- Store-Scoped Collections from original rules ---
        match /storePackages/{docId} { allow read, write: if hasStoreAccess(storeId); }
        match /storeRefills/{docId} { allow read, write: if hasStoreAccess(storeId); }
        match /storeFlavors/{docId} { allow read, write: if hasStoreAccess(storeId); }
        match /menuSchedules/{docId} { allow read, write: if hasStoreAccess(storeId); }
        match /kitchenLocations/{docId} { allow read, write: if hasStoreAccess(storeId); }
        match /tables/{docId} { allow read, write: if hasStoreAccess(storeId); }
        match /inventory/{docId} { allow read, write: if hasStoreAccess(storeId); }
        match /storeCharges/{docId} { allow read, write: if hasStoreAccess(storeId); }
        match /storeDiscounts/{docId} { allow read, write: if hasStoreAccess(storeId); }
        match /storeModesOfPayment/{docId} { allow read, write: if hasStoreAccess(storeId); }
        match /receiptSettings/{docId} { allow read, write: if hasStoreAccess(storeId); }
        match /counters/{docId} { allow read, write: if hasStoreAccess(storeId); }
        match /receipts/{receiptId} { allow read, write: if hasStoreAccess(storeId); }
        match /analytics/{dayId} { allow read, write: if hasStoreAccess(storeId); }
        match /analyticsMonths/{monthId} { allow read, write: if hasStoreAccess(storeId); }
        match /analyticsYears/{yearId} { allow read, write: if hasStoreAccess(storeId); }
        match /sessions/{sessionId}/{wildcard=**} { allow read, write: if hasStoreAccess(storeId); }
    }

    match /staff/{staffId} {
      allow get: if isOwner(staffId) || isPlatformAdmin();
      allow list: if isPlatformAdmin();
      allow create: if isCreatingOwnValidStaffDoc(staffId);

      // Allow user to update their own doc, but not the 'assignments' field.
      // That field should only be updated by a backend process.
      allow update: if (isUpdatingOwnValidStaffDoc(staffId) && !("assignments" in request.resource.data))
        || isPlatformAdmin();

      allow delete: if isPlatformAdmin();
    }
    
    // --- Global Collections from original rules ---
    match /products/{productId} { allow read: if isSignedIn(); allow write: if isPlatformAdmin(); }
    match /flavors/{flavorId} { allow read: if isSignedIn(); allow write: if isPlatformAdmin(); }
    match /refills/{refillId} { allow read: if isSignedIn(); allow write: if isPlatformAdmin(); }
    match /packages/{packageId} { allow read: if isSignedIn(); allow write: if isPlatformAdmin(); }
    match /addonCategories/{categoryId} { allow read: if isSignedIn(); allow write: if isPlatformAdmin(); }


    match /expenseEntries/{expenseEntryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isPlatformAdmin();
    }

    match /stores/{storeId}/staff/{staffId} {
      allow get, list: if hasStoreAccess(storeId);
      allow create: if canManageStoreStaff(storeId) && request.resource.data.staffId == staffId;
      allow update: if canManageStoreStaff(storeId) && request.resource.data.staffId == resource.data.staffId;
      allow delete: if canManageStoreStaff(storeId);
    }

    match /stores/{storeId}/ERP/{wildcard=**} {
      allow read, write: if hasStoreAccess(storeId);
    }

     // Default deny all access to other collections.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
