registry=https://registry.npmjs.org/

# More retries (default is often too low for CI)
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000

# Avoid short network cutoffs
network-timeout=120000

# Reduce extra network calls
fund=false
audit=false

# (optional) sometimes helps in CI
prefer-offline=true
